<div class="analysis">

  <% if @meta[:retracted] || @result[:retracted] %>
    <div class="flash flash--alert retracted-banner">
      <%= t("results.retracted_banner_html") %>
      <% if @meta.dig(:retraction, :reason).present? %>
        <span class="retracted-reason"><%= t("results.retracted_reason", reason: @meta[:retraction][:reason]) %></span>
      <% end %>
    </div>
  <% end %>

  <%# --- Article header --- %>
  <div class="article-header">
    <div class="article-meta">
      <span class="article-journal"><%= @meta[:journal] %></span>
      <span class="article-date"><%= @meta[:published]&.strftime("%B %Y") rescue @meta[:published] %></span>
      <% if @meta[:oa_status] && @meta[:oa_status] != "closed" %>
        <span class="oa-badge oa-badge--<%= @meta[:oa_status] %>"><%= t("results.access_badge", status: @meta[:oa_status].capitalize) %></span>
      <% elsif @meta[:oa_status] == "closed" %>
        <span class="oa-badge oa-badge--closed"><%= t("results.closed_access") %></span>
      <% end %>
    </div>
    <h1 class="article-title"><%= @meta[:title] %></h1>
    <div class="article-authors">
      <% @meta[:authors].each_with_index do |a, i| %>
        <span class="author-name"><%= a[:name] %><% if a[:h_index] %><span class="author-h-index" title="h-index">h:<%= a[:h_index] %></span><% end %></span><%= ", " unless i == @meta[:authors].length - 1 %>
      <% end %>
    </div>
    <% if @meta[:topics].any? %>
      <div class="article-topics">
        <% @meta[:topics].each do |topic| %>
          <span class="topic-badge"><%= topic %></span>
        <% end %>
      </div>
    <% end %>
    <a href="https://doi.org/<%= @meta[:doi] %>" target="_blank" rel="noopener" class="doi-link">
      doi.org/<%= @meta[:doi] %>
    </a>
  </div>

  <%# --- Global score --- %>
  <div class="global-score score--<%= @result[:color].gsub('-', '_') %>">
    <div class="grade-circle grade--<%= @result[:color].gsub('-', '_') %>">
      <%= @result[:grade] %>
    </div>
    <div class="global-details">
      <div class="global-number"><%= @result[:global_score] %><span>/100</span></div>
      <p class="global-summary"><%= @result[:summary] %></p>
      <% if @result[:notices]&.include?(:pubpeer) %>
        <p class="score-notice"><%= t("results.score_capped_pubpeer") %></p>
      <% end %>
    </div>
  </div>

  <%# --- Coverage transparency --- %>
  <% if (cov = @result[:coverage]) %>
    <p class="coverage-note">
      <%= t("results.coverage_html", counted: cov[:counted], total: cov[:total], pct: (cov[:weight_used] * 100).round) %>
      <% if cov[:unavailable].any? %>
        <%= t("results.coverage_unavailable", list: cov[:unavailable].join(", ")) %>
      <% end %>
    </p>
  <% end %>

  <%# --- Individual criteria --- %>
  <div class="criteria-section">
    <h2><%= t("results.criteria_breakdown") %></h2>
    <div class="criteria-list">
      <% @result[:criteria].each_value do |criterion| %>
        <div class="criterion-row criterion--<%= criterion[:color] %>">
          <div class="criterion-header">
            <span class="criterion-name"><%= criterion[:criterion] %></span>
            <span class="criterion-value"><%= criterion[:value] %></span>
            <div class="criterion-meter">
              <% if criterion[:level] %>
                <% criterion[:max_level].times do |i| %>
                  <span class="meter-dot <%= i < criterion[:level] ? "dot--filled dot--#{criterion[:color]}" : "dot--empty" %>"></span>
                <% end %>
              <% else %>
                <span class="meter-na"><%= t("results.na") %></span>
              <% end %>
            </div>
          </div>
          <p class="criterion-explanation"><%= criterion[:explanation] %></p>

          <% if criterion[:source_note] %>
            <p class="criterion-source"><%= t("results.source_label", source: criterion[:source_note]) %></p>
          <% end %>

          <%# PubPeer link if flagged %>
          <% if criterion[:pubpeer_url] %>
            <a href="<%= criterion[:pubpeer_url] %>" target="_blank" rel="noopener" class="pubpeer-link">
              <%= t("results.view_on_pubpeer") %>
            </a>
          <% end %>

          <%# Journal pedigree badges %>
          <% if criterion[:badges] %>
            <div class="criterion-badges">
              <% criterion[:badges].each do |badge| %>
                <span class="badge <%= badge[:present] ? 'badge--yes' : 'badge--no' %>">
                  <%= badge[:present] ? "✓" : "✗" %> <%= badge[:label] %>
                </span>
              <% end %>
            </div>
          <% end %>

          <%# Detected items (Open Science signals, retracted reference DOIs) %>
          <% if criterion[:detected]&.any? %>
            <div class="detected-list">
              <% criterion[:detected].each do |d| %>
                <span class="detected-item"><%= d %></span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# --- AI-assisted insights (optional, informational, not scored) --- %>
  <% if @ai.present? && (@ai[:summary].present? || @ai[:points]&.any?) %>
    <div class="ai-section">
      <h2><%= t("results.ai.title") %> <span class="ai-badge"><%= t("results.ai.experimental") %></span></h2>
      <% if @ai[:summary].present? %>
        <p class="ai-summary"><%= @ai[:summary] %></p>
      <% end %>
      <% if @ai[:points]&.any? %>
        <ul class="ai-points">
          <% @ai[:points].each do |point| %>
            <li><%= point %></li>
          <% end %>
        </ul>
      <% end %>
      <p class="ai-disclaimer"><%= t("results.ai.disclaimer") %></p>
    </div>
  <% end %>

  <%# --- Abstract --- %>
  <% if @meta[:abstract].present? %>
    <div class="abstract-section">
      <h2><%= t("results.abstract") %></h2>
      <p class="abstract-text"><%= @meta[:abstract] %></p>
    </div>
  <% end %>

  <div class="actions">
    <%= link_to t("results.analyze_another"), new_analysis_path, class: "btn-analyze" %>
  </div>

  <p class="disclaimer"><%= t("results.disclaimer") %></p>
</div>
