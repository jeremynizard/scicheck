<div class="home">
  <div class="hero">
    <h1><%= t("home.heading") %></h1>
    <p><%= t("home.intro") %></p>

    <%= form_with url: analyses_path, method: :post, class: "doi-form",
          data: { turbo: false, controller: "analyze", action: "submit->analyze#submit" } do |f| %>
      <div class="doi-input-wrapper">
        <%= f.text_field :doi,
            placeholder: t("home.placeholder"),
            class: "doi-input",
            autofocus: true,
            required: true %>
        <%= f.submit t("home.analyze"), class: "btn-analyze", data: { analyze_target: "submit" } %>
      </div>
      <p class="doi-hint"><%= t("home.hint") %></p>
    <% end %>

    <div class="loading-overlay hidden" data-analyze-target="overlay">
      <div class="loading-box">
        <div class="spinner"></div>
        <p class="loading-title"><%= t("home.loading_title") %></p>
        <p class="loading-detail"><%= t("home.loading_detail") %></p>
      </div>
    </div>
  </div>

  <div class="criteria-preview">
    <h2><%= t("home.what_we_analyze") %></h2>
    <div class="criteria-grid">
      <%
        cards = [
          { key: :study_type,           weight: 25, source_html: false, how_html: true,  weight_html: false },
          { key: :review_pedigree,      weight: 20, source_html: false, how_html: false, weight_html: false },
          { key: :review_process,       weight: 15, source_html: true,  how_html: false, weight_html: false },
          { key: :open_science,         weight: 10, source_html: false, how_html: true,  weight_html: false },
          { key: :pubpeer,              weight: 10, source_html: false, how_html: false, weight_html: true },
          { key: :citation_profile,     weight: 8,  source_html: false, how_html: true,  weight_html: false },
          { key: :retracted_references, weight: 7,  source_html: true,  how_html: false, weight_html: false },
          { key: :author_track_record,  weight: 5,  source_html: false, how_html: true,  weight_html: false }
        ]
      %>
      <% cards.each do |c| %>
        <% base = "home.cards.#{c[:key]}" %>
        <details class="criterion-card">
          <summary>
            <strong><%= t("#{base}.title") %></strong>
            <span class="card-weight"><%= c[:weight] %>%</span>
            <p><%= t("#{base}.blurb") %></p>
          </summary>
          <div class="card-details">
            <dl>
              <dt><%= t("home.source") %></dt>
              <dd><%= c[:source_html] ? t("#{base}.source_html") : t("#{base}.source") %></dd>
              <dt><%= t("home.how_it_works") %></dt>
              <dd><%= c[:how_html] ? t("#{base}.how_html") : t("#{base}.how") %></dd>
              <dt><%= t("home.weight") %></dt>
              <dd><%= c[:weight_html] ? t("#{base}.weight_html") : t("home.weight_of_global", pct: c[:weight]) %></dd>
            </dl>
          </div>
        </details>
      <% end %>
    </div>
  </div>
</div>
